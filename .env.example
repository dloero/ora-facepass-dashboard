# Apollo.io API
APOLLO_API_KEY=your_apollo_api_key_here

# Slack
# Incoming Webhook URL for the channel where Dereck should receive the report
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# Optional: Slack user ID to @mention in the message (e.g. U0123ABCDEF)
SLACK_DERECK_USER_ID=

# Lead aging threshold (days with no activity before flagging)
LEAD_AGING_THRESHOLD_DAYS=3

# Days idle before a lead is flagged for reassignment (must be >= LEAD_AGING_THRESHOLD_DAYS)
LEAD_REASSIGNMENT_THRESHOLD_DAYS=7

# Apollo.io label or list name that identifies Ora FacePass leads
# Leave blank to scan all contacts
APOLLO_LEAD_LABEL=Ora FacePass

# ─── Demo Follow-Up Drafter ───────────────────────────────────────────────────

# GoHighLevel (GHL) API key — generate under Settings > Integrations > API Key
GHL_API_KEY=your_ghl_api_key_here

# GHL Location ID — found in Settings > Business Profile or in the URL (?locationId=...)
GHL_LOCATION_ID=your_ghl_location_id_here

# Optional: restrict to a specific GHL calendar ID (leave blank to scan all calendars)
GHL_CALENDAR_ID=

# Calendly booking link included in every follow-up email draft
CALENDLY_LINK=https://calendly.com/orafacepass
